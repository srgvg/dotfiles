#!/usr/bin/env bash
set -o nounset
set -o errexit
set -o pipefail

# c-basic-offset: 4; tab-width: 4; indent-tabs-mode: t
# vi: set shiftwidth=4 tabstop=4 noexpandtab:
# :indentSize=4:tabSize=4:noTabs=false:

# i3-get-window-criteria - Get criteria for use with i3 config commands

# source https://faq.i3wm.org/question/2172/how-do-i-find-the-criteria-for-use-with-i3-config-commands-like-for_window-eg-to-force-splashscreens-and-dialogs-to-show-in-floating-mode/

# To use, run this script, then click on a window.
# Output is in the format: [<name>=<value> <name>=<value> ...]

# Known problem: when WM_NAME is used as fallback for the 'title="<string>"'
# criterion, quotes in "<string>" are not escaped properly. This is a problem
# with the output of `xprop`,
# reported upstream: https://bugs.freedesktop.org/show_bug.cgi?id=66807

set -o nounset
set -o errexit
set -o pipefail


# shellcheck disable=SC1090
source "$HOME/bin/common.bash"

app_pid="$(swaymsg -t get_tree | jq -r 'first(.. | objects | select(.focused? == true)) | .pid // 0' 2>/dev/null || echo 0)"

# Foot runs in server mode: every window shares the one `foot --server` pid, so probing it
# (pgrep -P → pwdx) returns an arbitrary sibling shell's cwd, not the focused window's. Bail and
# emit nothing — ~/bin/term owns foot windows via foot's own OSC-7 spawn (spawn-terminal). comm
# resolves to "foot" for both the shared server and any standalone foot. See foot-migration.md §0d.
[ "${app_pid:-0}" -gt 1 ] 2>/dev/null && [ "$(ps -o comm= -p "${app_pid}" 2>/dev/null)" = foot ] && exit 0

# Non-foot windows (alacritty / any single-process emulator) report a real per-window pid:
# focused pid → first child shell → its cwd.
if [ "${app_pid:-0}" -gt 1 ] 2>/dev/null
then
	child_pid="$(pgrep -P "${app_pid}" 2>/dev/null | head -n1 || true)"
	[ -n "${child_pid:-}" ] && cwd="$(pwdx "${child_pid}" 2>/dev/null | cut -d: -f2 | xargs -n1 || true)"
fi

# Emit only a real home-rooted path; leave empty/non-home for ~/bin/term to map to $HOME (term:55).
[[ "${cwd:-}" = /home* ]] && echo -n "${cwd}"
