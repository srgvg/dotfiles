#!/usr/bin/env bash
#
# term-run — launch the session terminal with a given app-id + title, running a
# command. Emulator-agnostic: the ONLY CLI difference between alacritty and foot
# is the app-id flag (--class vs --app-id); -e, --title and --working-directory
# are identical (foot accepts and ignores -e for xterm compat).
#
# The emulator is chosen by $TERMINAL (default foot) — set in
# ~/.config/environment.d/sway.conf (and ~/.bashrc.d/4-windowmanager.bash default).
# Set TERMINAL=alacritty to fall back.
#
# Usage: term-run <app-id> [--title <title>] -- <command> [args...]

set -o nounset

id="$1"; shift
title="$id"
if [ "${1:-}" = "--title" ]; then title="$2"; shift 2; fi
if [ "${1:-}" = "--" ]; then shift; fi

term="${TERMINAL:-foot}"
term="${term%% *}"   # bare emulator only; tolerate a polluted multi-word $TERMINAL
case "${term##*/}" in
	foot) idflag="--app-id" ;;
	*)    idflag="--class" ;;
esac

# foot runs as standalone instances (one process per window); server mode (footclient) was
# reverted — a `foot --server` crash took every window down at once. See
# ~/etc/docs/foot-migration.md §0f.
exec "$term" "$idflag" "$id" --title "$title" -e "$@"
