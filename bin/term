#!/usr/bin/env bash

# c-basic-offset: 4; tab-width: 4; indent-tabs-mode: t
# vi: set shiftwidth=4 tabstop=4 noexpandtab:
# :indentSize=4:tabSize=4:noTabs=false:

set -o nounset
set -o errexit
set -o pipefail

# shellcheck disable=SC1090
source "$HOME/bin/common.bash"

###############################################################################

#DEBUG=1
#TERMINAL="/usr/bin/gnome-terminal --geometry 100x40+0+0"
TERMINAL="${TERMINAL:-foot}"
TERMINAL="${TERMINAL%% *}"   # bare emulator only; never inherit/compound a built command line
TERMINAL_COMMAND="${TERMINAL_COMMAND:-$TERMINAL -e}"

# Emulator-agnostic app-id flag: --class (alacritty) vs --app-id (foot).
# $TERMINAL is the single switch (set in ~/.config/environment.d/sway.conf).
case "${TERMINAL##*/}" in
	foot) IDFLAG="--app-id" ;;
	*)    IDFLAG="--class" ;;
esac

CARGS="$*"

# Build the launch command in a local var; do NOT mutate the exported $TERMINAL
# (children must inherit the bare emulator name, not a full command line).
# Server mode: when the emulator is foot and the foot --server socket is up, hand off
# to footclient (instant startup, shared font/glyph caches). -E makes the new terminal
# inherit THIS shell's environment (SSH agent, kube context) rather than the server's.
# Falls back to plain foot if the socket is absent. See ~/etc/docs/foot-migration.md.
_footsock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/foot.sock"
if [ "$TERMINAL" = foot ] && [ -S "$_footsock" ]
then
	# --server-socket points straight at the systemd socket (%t/foot.sock), avoiding
	# footclient's default foot-$WAYLAND_DISPLAY.sock miss + stderr fallback warning.
	cmd="footclient -E --server-socket=$_footsock"
else
	cmd="$TERMINAL"
fi

if [ -z "$CARGS" ]
then
	if [ "$(basename $0)" = "termf" ]
	then
		#cmd="$TERMINAL --role gnome-terminal-floating"
		cmd="$cmd $IDFLAG terminal-floating"
	else
		PWD="$(sway-get-window-cwd ||:)"
		[ -z "${PWD}" ] || [ "$PWD" = "/snap/bin" ] && PWD="$HOME"
		#cmd="$TERMINAL --role gnome-terminal-tiled"
		cmd="$cmd $IDFLAG terminal-tiled"
		cmd="$cmd --working-directory=${PWD}"
	fi
else
	cmd="$cmd $CARGS"
fi

if ifdebug1
then
	mkdir -p $HOMETMPDIR/tmp/term/
	filename=$HOME/tmp/term/$(date +%Y%m%d-%H%M%S).trace.log
	ln -nfs $filename $HOMETMPDIR/tmp/term/latest.trace.log
	exec strace -o $filename -tt -T -y -yy -f $cmd
else
	exec $cmd
fi
