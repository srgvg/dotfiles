#!/usr/bin/env bash

# c-basic-offset: 4; tab-width: 4; indent-tabs-mode: t
# vi: set shiftwidth=4 tabstop=4 noexpandtab:
# :indentSize=4:tabSize=4:noTabs=false:

set -o nounset
set -o errexit
set -o pipefail

# shellcheck disable=SC1090
source "$HOME/bin/common.bash"

###############################################################################

#DEBUG=1
#TERMINAL="/usr/bin/gnome-terminal --geometry 100x40+0+0"
TERMINAL="${TERMINAL:-foot}"
TERMINAL="${TERMINAL%% *}"   # bare emulator only; never inherit/compound a built command line
TERMINAL_COMMAND="${TERMINAL_COMMAND:-$TERMINAL -e}"

# Emulator-agnostic app-id flag: --class (alacritty) vs --app-id (foot).
# $TERMINAL is the single switch (set in ~/.config/environment.d/sway.conf).
case "${TERMINAL##*/}" in
	foot) IDFLAG="--app-id" ;;
	*)    IDFLAG="--class" ;;
esac

CARGS="$*"

# Build the launch command in a local var; do NOT mutate the exported $TERMINAL
# (children must inherit the bare emulator name, not a full command line).
# foot runs as standalone instances (one process per window) — server mode was reverted
# because a `foot --server` crash took every window down at once. See
# ~/etc/docs/foot-migration.md §0f.
cmd="$TERMINAL"

if [ -z "$CARGS" ]
then
	if [ "$(basename $0)" = "termf" ]
	then
		#cmd="$TERMINAL --role gnome-terminal-floating"
		cmd="$cmd $IDFLAG terminal-floating"
	else
		# Same-dir spawn: if foot is the emulator and a foot window is focused, let foot spawn the
		# new window itself via its OSC-7 tracking — inject its spawn-terminal binding with wtype.
		# OSC-7 is the authoritative cwd: it survives OSC-2 title clobbering (claude/vim/ssh) and
		# needs no pid probing. Non-foot windows fall through to the sway-get-window-cwd pid
		# method. Needs foot.ini's Mod4+Control+Shift+n binding — see
		# ~/etc/docs/foot-migration.md §0d.
		_fpid="$(swaymsg -t get_tree | jq -r 'first(.. | objects | select(.focused? == true)) | .pid // 0' 2>/dev/null || echo 0)"
		if [ "$TERMINAL" = foot ] && [ "${_fpid:-0}" -gt 1 ] 2>/dev/null && [ "$(ps -o comm= -p "${_fpid}" 2>/dev/null)" = foot ]
		then
			exec wtype -M ctrl -M shift -k n -m shift -m ctrl
		fi
		PWD="$(sway-get-window-cwd ||:)"
		[ -z "${PWD}" ] || [ "$PWD" = "/snap/bin" ] && PWD="$HOME"
		#cmd="$TERMINAL --role gnome-terminal-tiled"
		cmd="$cmd $IDFLAG terminal-tiled"
		cmd="$cmd --working-directory=${PWD}"
	fi
else
	cmd="$cmd $CARGS"
fi

if ifdebug1
then
	mkdir -p $HOMETMPDIR/tmp/term/
	filename=$HOME/tmp/term/$(date +%Y%m%d-%H%M%S).trace.log
	ln -nfs $filename $HOMETMPDIR/tmp/term/latest.trace.log
	exec strace -o $filename -tt -T -y -yy -f $cmd
else
	exec $cmd
fi
