#!/usr/bin/env bash

# c-basic-offset: 4; tab-width: 4; indent-tabs-mode: t
# vi: set shiftwidth=4 tabstop=4 noexpandtab:
# :indentSize=4:tabSize=4:noTabs=false:

set -o nounset
set -o errexit
set -o pipefail

# shellcheck disable=SC1090
source "$HOME/bin/common.bash"

###############################################################################

DO_IT=false
FAILED=0

usage() {
	echo -e "${echo_bold_white}Usage:${echo_normal} $(basename "$0") [-d|--do-it]"
	echo
	echo "  Lists local and remote branches already merged or rebased into the repo's default branch."
	echo "  In dry-run mode, prompts for confirmation before deleting."
	echo "  -d, --do-it    Delete the stale branches without prompting"
}

while [[ $# -gt 0 ]]; do
	case $1 in
		-d|--do-it) DO_IT=true; shift ;;
		-h|--help)  usage; exit 0 ;;
		*) echo -e "${echo_red}Unknown option: $1${echo_normal}" >&2; usage >&2; exit 1 ;;
	esac
done

if ! git rev-parse --git-dir &>/dev/null; then
	echo -e "${echo_red}Not a git repository.${echo_normal}" >&2
	exit 1
fi

# Detect remote from current branch, fall back to origin
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
REMOTE=$(git config --get "branch.${CURRENT_BRANCH}.remote" 2>/dev/null || echo "origin")

# Fetch from remote (non-fatal)
echo -e "${echo_lightgray}Fetching from ${REMOTE}...${echo_normal}"
if git fetch "$REMOTE" 2>/dev/null; then
	# Ensure remote HEAD is resolved so symbolic-ref works
	git remote set-head "$REMOTE" --auto &>/dev/null || true
else
	echo -e "  ${echo_yellow}Could not reach ${REMOTE} — proceeding without fetch.${echo_normal}"
fi

# Detect default branch via remote's HEAD
DEFAULT_BRANCH=$(git symbolic-ref "refs/remotes/${REMOTE}/HEAD" 2>/dev/null \
	| sed "s|refs/remotes/${REMOTE}/||") || true
if [[ -z "${DEFAULT_BRANCH:-}" ]]; then
	for b in main master; do
		if git show-ref --verify --quiet "refs/remotes/${REMOTE}/${b}"; then
			DEFAULT_BRANCH=$b
			break
		fi
	done
fi
if [[ -z "${DEFAULT_BRANCH:-}" ]]; then
	echo -e "${echo_red}Cannot determine default branch of ${REMOTE}.${echo_normal}" >&2
	exit 1
fi

BASE_REF="${REMOTE}/${DEFAULT_BRANCH}"
echo -e "  ${echo_bold_white}Base:${echo_normal} ${BASE_REF}"

# Fast-forward local default branch to match remote
if git show-ref --verify --quiet "refs/heads/${DEFAULT_BRANCH}"; then
	local_sha=$(git rev-parse "${DEFAULT_BRANCH}")
	remote_sha=$(git rev-parse "${BASE_REF}")
	if [[ "$local_sha" == "$remote_sha" ]]; then
		echo -e "  ${echo_green}${DEFAULT_BRANCH} is up to date.${echo_normal}"
	elif git merge-base --is-ancestor "$local_sha" "$remote_sha" 2>/dev/null; then
		# Can fast-forward — do it without checking out
		if [[ "$CURRENT_BRANCH" == "$DEFAULT_BRANCH" ]]; then
			git merge --ff-only "$BASE_REF" &>/dev/null \
				&& echo -e "  ${echo_green}Fast-forwarded ${DEFAULT_BRANCH}.${echo_normal}" \
				|| echo -e "  ${echo_yellow}Could not fast-forward ${DEFAULT_BRANCH}.${echo_normal}"
		else
			git fetch "$REMOTE" "${DEFAULT_BRANCH}:${DEFAULT_BRANCH}" &>/dev/null \
				&& echo -e "  ${echo_green}Fast-forwarded ${DEFAULT_BRANCH}.${echo_normal}" \
				|| echo -e "  ${echo_yellow}Could not fast-forward ${DEFAULT_BRANCH}.${echo_normal}"
		fi
	else
		echo -e "  ${echo_yellow}${DEFAULT_BRANCH} has diverged from ${BASE_REF} — not touching it.${echo_normal}"
	fi
fi
echo

# Collect stale local branches — single batch call for merged, then cherry for the rest
declare -a MERGED=()
declare -a REBASED=()
declare -a LOCAL_NOT_MERGED=()

while IFS= read -r branch; do
	[[ "$branch" == "$DEFAULT_BRANCH" ]] && continue
	MERGED+=("$branch")
done < <(git for-each-ref --merged="$BASE_REF" --format='%(refname:short)' 'refs/heads/')

while IFS= read -r branch; do
	[[ "$branch" == "$DEFAULT_BRANCH" ]] && continue
	LOCAL_NOT_MERGED+=("$branch")
done < <(git for-each-ref --no-merged="$BASE_REF" --format='%(refname:short)' 'refs/heads/')

# Collect stale remote branches — same pattern
declare -a REMOTE_MERGED=()
declare -a REMOTE_REBASED=()
declare -a REMOTE_NOT_MERGED=()

while IFS= read -r branch; do
	[[ "$branch" == "HEAD" ]] && continue
	[[ "$branch" == "$DEFAULT_BRANCH" ]] && continue
	REMOTE_MERGED+=("$branch")
done < <(git for-each-ref --merged="$BASE_REF" \
	--format='%(refname:short)' "refs/remotes/${REMOTE}/" \
	| sed "s|^${REMOTE}/||")

while IFS= read -r branch; do
	[[ "$branch" == "HEAD" ]] && continue
	[[ "$branch" == "$DEFAULT_BRANCH" ]] && continue
	REMOTE_NOT_MERGED+=("$branch")
done < <(git for-each-ref --no-merged="$BASE_REF" \
	--format='%(refname:short)' "refs/remotes/${REMOTE}/" \
	| sed "s|^${REMOTE}/||")

# Cherry-pick detection for non-merged branches — all jobs run in parallel
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

for i in "${!LOCAL_NOT_MERGED[@]}"; do
	git cherry "$BASE_REF" "${LOCAL_NOT_MERGED[$i]}" > "${tmpdir}/l${i}" 2>/dev/null &
done
for i in "${!REMOTE_NOT_MERGED[@]}"; do
	git cherry "$BASE_REF" "${REMOTE}/${REMOTE_NOT_MERGED[$i]}" > "${tmpdir}/r${i}" 2>/dev/null &
done

wait
for i in "${!LOCAL_NOT_MERGED[@]}"; do
	grep -q '^+' "${tmpdir}/l${i}" 2>/dev/null || REBASED+=("${LOCAL_NOT_MERGED[$i]}")
done
for i in "${!REMOTE_NOT_MERGED[@]}"; do
	grep -q '^+' "${tmpdir}/r${i}" 2>/dev/null || REMOTE_REBASED+=("${REMOTE_NOT_MERGED[$i]}")
done

LOCAL_TOTAL=$(( ${#MERGED[@]} + ${#REBASED[@]} ))
REMOTE_TOTAL=$(( ${#REMOTE_MERGED[@]} + ${#REMOTE_REBASED[@]} ))
TOTAL=$(( LOCAL_TOTAL + REMOTE_TOTAL ))

if [[ $TOTAL -eq 0 ]]; then
	echo -e "${echo_green}No stale branches found.${echo_normal}"
	exit 0
fi

# Column width for alignment
MAX_WIDTH=0
for branch in "${MERGED[@]}" "${REBASED[@]}" "${REMOTE_MERGED[@]}" "${REMOTE_REBASED[@]}"; do
	(( ${#branch} > MAX_WIDTH )) && MAX_WIDTH=${#branch}
done

# Colors are embedded in the format string (not as %s args) so printf renders them
print_branch() {
	local branch=$1
	local label=$2   # plain text: "merged " or "rebased"
	local color=$3   # color escape sequence
	local info
	info=$(git log -1 --format='%h "%s" (%cr)' "$branch" 2>/dev/null || echo "")
	printf "  ${color}%-${MAX_WIDTH}s  %s${echo_normal}  ${echo_lightgray}%s${echo_normal}\n" \
		"$branch" "$label" "$info"
}

print_remote_branch() {
	local branch=$1
	local label=$2
	local color=$3
	local info
	info=$(git log -1 --format='%h "%s" (%cr)' "${REMOTE}/${branch}" 2>/dev/null || echo "")
	printf "  ${color}%-${MAX_WIDTH}s  %s${echo_normal}  ${echo_lightgray}%s${echo_normal}\n" \
		"$branch" "$label" "$info"
}

delete_branch() {
	local branch=$1
	local flag=$2   # -d or -D
	if [[ "$branch" == "$CURRENT_BRANCH" ]]; then
		echo -e "    ${echo_yellow}(skipping — currently checked out)${echo_normal}"
	else
		local err
		if ! err=$(git branch "$flag" "$branch" 2>&1); then
			echo -e "    ${echo_red}(failed: ${err})${echo_normal}" >&2
			(( FAILED++ )) || true
		fi
	fi
}

delete_remote_branch() {
	local branch=$1
	local err
	if ! err=$(git push "$REMOTE" --delete "$branch" 2>&1); then
		echo -e "    ${echo_red}(failed: ${err})${echo_normal}" >&2
		(( FAILED++ )) || true
	fi
}

if $DO_IT; then
	if [[ $LOCAL_TOTAL -gt 0 ]]; then
		echo -e "${echo_bold_white}Deleting ${LOCAL_TOTAL} stale local branch(es):${echo_normal}"
		for branch in "${MERGED[@]}"; do
			print_branch "$branch" "merged " "$echo_green"
			delete_branch "$branch" -d
		done
		for branch in "${REBASED[@]}"; do
			print_branch "$branch" "rebased" "$echo_yellow"
			delete_branch "$branch" -D
		done
	fi
	if [[ $REMOTE_TOTAL -gt 0 ]]; then
		[[ $LOCAL_TOTAL -gt 0 ]] && echo
		echo -e "${echo_bold_white}Deleting ${REMOTE_TOTAL} stale remote branch(es):${echo_normal}"
		for branch in "${REMOTE_MERGED[@]}"; do
			print_remote_branch "$branch" "merged " "$echo_green"
			delete_remote_branch "$branch"
		done
		for branch in "${REMOTE_REBASED[@]}"; do
			print_remote_branch "$branch" "rebased" "$echo_yellow"
			delete_remote_branch "$branch"
		done
	fi
else
	if [[ $LOCAL_TOTAL -gt 0 ]]; then
		echo -e "${echo_bold_white}Stale local branches (${LOCAL_TOTAL}):${echo_normal}"
		for branch in "${MERGED[@]}"; do
			print_branch "$branch" "merged " "$echo_green"
		done
		for branch in "${REBASED[@]}"; do
			print_branch "$branch" "rebased" "$echo_yellow"
		done
	fi
	if [[ $REMOTE_TOTAL -gt 0 ]]; then
		[[ $LOCAL_TOTAL -gt 0 ]] && echo
		echo -e "${echo_bold_white}Stale remote branches (${REMOTE_TOTAL}):${echo_normal}"
		for branch in "${REMOTE_MERGED[@]}"; do
			print_remote_branch "$branch" "merged " "$echo_green"
		done
		for branch in "${REMOTE_REBASED[@]}"; do
			print_remote_branch "$branch" "rebased" "$echo_yellow"
		done
	fi
	echo
	CONFIRM=""
	read -rp "Delete these ${TOTAL} branch(es)? Enter Y to confirm: " CONFIRM || true
	if [[ "$CONFIRM" == "Y" ]]; then
		for branch in "${MERGED[@]}"; do
			delete_branch "$branch" -d
		done
		for branch in "${REBASED[@]}"; do
			delete_branch "$branch" -D
		done
		for branch in "${REMOTE_MERGED[@]}"; do
			delete_remote_branch "$branch"
		done
		for branch in "${REMOTE_REBASED[@]}"; do
			delete_remote_branch "$branch"
		done
	fi
fi

if (( FAILED > 0 )); then
	echo -e "${echo_red}${FAILED} branch(es) could not be deleted.${echo_normal}" >&2
	exit 1
fi
